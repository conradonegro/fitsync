# =============================================================================
# FitSync Environment Variables
# =============================================================================
# Copy this file to .env.local in the relevant app directory.
# NEVER commit .env.local or any file containing real secrets.
# The service_role key MUST NOT appear in any client app config.
# =============================================================================

# --- Supabase (shared across apps) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Supabase server-only (apps/web server context ONLY) ---
# NEVER use this in mobile or client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Sentry ---
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# --- Resend (Edge Functions only) ---
RESEND_API_KEY=your-resend-api-key

# --- Stripe (Phase 2 - stubbed) ---
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
