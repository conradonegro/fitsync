# apps/mobile — copy to .env.local and fill in real values.
# NEVER commit .env.local.
#
# These are injected at BUILD TIME via app.config.ts.
# Changing them requires a new Expo start (dev) or EAS Build (production).
# Access at runtime via: Constants.expoConfig?.extra?.supabaseUrl

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-local-anon-key
SENTRY_DSN=
EAS_PROJECT_ID=your-eas-project-id
