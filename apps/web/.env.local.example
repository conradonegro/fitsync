# apps/web — copy to .env.local and fill in real values.
# NEVER commit .env.local.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_.
# Only used in Server Components, Route Handlers, and middleware.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_ROLE_KEY is intentionally absent — it lives only in CI vaults
# and Supabase project settings, never in .env.local (ADR non-negotiable).

# Sentry (leave empty for local dev)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
