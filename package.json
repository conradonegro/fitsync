{
  "name": "fitsync",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20.20.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "gen:types": "supabase gen types typescript --local > packages/database-types/src/types.ts",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "sharp",
      "unrs-resolver",
      "expo-sqlite"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
