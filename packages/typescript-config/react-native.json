{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-native",
    "allowJs": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "customConditions": ["react-native"],
    "strict": true
  },
  "exclude": ["node_modules"]
}
